{
  "manifest_version": 3,
  "name": "WyScout Spoiler Blocker",
  "version": "1.1.5",
  "description": "Hides match scores on WyScout to prevent spoilers",
  "permissions": ["storage"],
  "host_permissions": [
    "https://wyscout.hudl.com/*",
    "https://wyscout-apps.hudl.com/*",
    "https://*.wyscout.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://wyscout.hudl.com/*",
        "https://wyscout-apps.hudl.com/*",
        "https://*.wyscout.com/*"
      ],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
